{ pkgs, ... }: {
  # قناة التحديثات
  channel = "stable-23.11";

  # الحزم المطلوبة (Java 17 والأندرويد)
  packages = [
    pkgs.jdk17
    pkgs.android-sdk
    pkgs.gradle
  ];

  # تفعيل الإضافات والمحاكي
  idx = {
    extensions = [
      "vscjava.vscode-java-pack"
      "vscjava.vscode-gradle"
    ];

    previews = {
      enable = true;
      previews = {
        android = {
          command = [
            "./gradlew"
            "assembleDebug"
            "--no-daemon"
          ];
          manager = "android";
        };
      };
    };
  };
}
